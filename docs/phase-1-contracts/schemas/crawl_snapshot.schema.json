{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase1/crawl_snapshot.schema.json",
  "title": "CrawlSnapshot",
  "type": "object",
  "required": [
    "run_id",
    "contract_version",
    "stage",
    "stage_version",
    "base_url",
    "pages",
    "timestamps"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "contract_version": {"type": "string", "const": "v1"},
    "stage": {"type": "string", "const": "crawl"},
    "stage_version": {"type": "string"},
    "base_url": {"type": "string", "format": "uri"},
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "title", "elements"],
        "properties": {
          "url": {"type": "string"},
          "title": {"type": "string"},
          "elements": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "text", "selector", "visible", "interactive"],
              "properties": {
                "type": {"type": "string", "enum": ["button", "input", "select", "link", "form", "checkbox", "radio", "textarea", "other"]},
                "text": {"type": "string"},
                "selector": {"type": "string"},
                "attributes": {"type": "object", "additionalProperties": {"type": "string"}},
                "visible": {"type": "boolean"},
                "interactive": {"type": "boolean"}
              },
              "additionalProperties": false
            }
          },
          "links": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "timestamps": {
      "type": "object",
      "required": ["started_at", "completed_at"],
      "properties": {
        "started_at": {"type": "string", "format": "date-time"},
        "completed_at": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
