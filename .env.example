# =============================================================================
# AI Test Case Generator - Environment Configuration TEMPLATE
# Copy this file to .env and fill in your actual values.
# =============================================================================

OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=120

BACKLOG_API_BASE_URL=http://YOUR_BACKLOG_API_URL
BACKLOG_API_KEY=YOUR_API_KEY_HERE

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

PLAYWRIGHT_SLOW_MO=1500
PLAYWRIGHT_HEADLESS=false

# Production queue guardrails
EXECUTION_MAX_QUEUE_SIZE=20
EXECUTION_QUEUE_POLL_MS=500
EXECUTION_DISPATCHER_WORKERS=1
EXECUTION_DISPATCHER_AUTO_START=true
EXECUTION_RUN_TIMEOUT_SECONDS=900
EXECUTION_SCRIPT_TIMEOUT_SECONDS=12
EXECUTION_PENDING_TTL_SECONDS=3600

# Phase 10 runtime policy
EXECUTION_VISUAL_SLOW_MO_MS=1000
EXECUTION_MAX_PARALLEL_WORKERS=1
EXECUTION_CAPTURE_VIDEO=true
EXECUTION_VIDEO_WIDTH=1280
EXECUTION_VIDEO_HEIGHT=720

# Operator access control (Phase 14)
OPERATOR_REQUIRE_API_KEY=false
OPERATOR_API_KEY=change-me
OPERATOR_VIEWER_KEY=
OPERATOR_EXECUTOR_KEY=
OPERATOR_ADMIN_KEY=

# Audit integrity (Phase 15)
AUDIT_SIGNING_SECRET=

# Operator incident policy (Phase 16)
OPERATOR_AUTH_FAILURE_WINDOW_SECONDS=300
OPERATOR_AUTH_MAX_FAILURES=5
OPERATOR_AUTH_LOCKOUT_SECONDS=600

# Operator incident webhook alerts (Phase 17)
OPERATOR_ALERT_WEBHOOK_URL=
OPERATOR_ALERT_TIMEOUT_SECONDS=5
OPERATOR_ALERT_CHANNEL=webhook
OPERATOR_ALERT_MAX_RETRIES=3
OPERATOR_ALERT_RETRY_BASE_MS=300

# Final ops readiness threshold (Phase 20)
OPERATOR_SECURITY_OPEN_INCIDENT_THRESHOLD=0
