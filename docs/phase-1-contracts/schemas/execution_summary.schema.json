{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase1/execution_summary.schema.json",
  "title": "ExecutionSummary",
  "type": "object",
  "required": [
    "run_id",
    "contract_version",
    "stage",
    "stage_version",
    "story_id",
    "status",
    "total",
    "passed",
    "failed",
    "skipped",
    "results",
    "timestamps"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "contract_version": {"type": "string", "const": "v1"},
    "stage": {"type": "string", "const": "execution"},
    "stage_version": {"type": "string"},
    "story_id": {"type": "string"},
    "status": {"type": "string", "enum": ["completed", "failed"]},
    "total": {"type": "integer", "minimum": 0},
    "passed": {"type": "integer", "minimum": 0},
    "failed": {"type": "integer", "minimum": 0},
    "skipped": {"type": "integer", "minimum": 0},
    "duration_ms": {"type": "integer", "minimum": 0},
    "video_path": {"type": "string"},
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test_case_id", "title", "status"],
        "properties": {
          "test_case_id": {"type": "string"},
          "title": {"type": "string"},
          "status": {"type": "string", "enum": ["passed", "failed", "skipped"]},
          "duration_ms": {"type": "integer", "minimum": 0},
          "error_message": {"type": "string"},
          "screenshot_path": {"type": "string"},
          "dom_snapshot_path": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "timestamps": {
      "type": "object",
      "required": ["started_at", "completed_at"],
      "properties": {
        "started_at": {"type": "string", "format": "date-time"},
        "completed_at": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
